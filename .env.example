# ------------------------------------------------------------------
# CIO Analytics PoC — environment variables
# Copy to .env.local for local dev, or set in Azure App Service
# Configuration → Application settings when deployed.
# ------------------------------------------------------------------

# --- Foundry (Claude in Microsoft Foundry) ---
# The resource name from Azure Foundry, e.g. "atea-cio-foundry" if the
# endpoint is https://atea-cio-foundry.services.ai.azure.com/anthropic
FOUNDRY_RESOURCE=

# API key from Azure Portal → your Foundry resource → "Endpoints and keys"
FOUNDRY_API_KEY=

# Model deployment names (match what you deployed in Foundry)
WRITER_MODEL=claude-sonnet-4-6
TRANSLATOR_MODEL=claude-haiku-4-5
REVIEWER_MODEL=claude-opus-4-6

# --- Storage ---
# "local"  = JSON files under .local-* folders (dev only)
# "azure"  = Azure Blob Storage
STORAGE_MODE=local

# Only needed when STORAGE_MODE=azure
# For Azurite local dev: UseDevelopmentStorage=true
# For Azure: the full connection string OR use managed identity in production
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER_PROMPTS=prompts
AZURE_STORAGE_CONTAINER_ARTICLES=articles
AZURE_STORAGE_CONTAINER_SOURCES=sources
AZURE_STORAGE_CONTAINER_USERS=users
AZURE_STORAGE_CONTAINER_EVALUATIONS=evaluations

# --- Auth (PoC only) ---
# Leave empty locally for no auth. Set in App Service for the deployed app.
# HTTP Basic Auth: any username works, password must match this value.
POC_PASSWORD=

# --- Observability ---
LOG_LEVEL=info
